MYSQL_DATABASE=fms_auth
MYSQL_USER=fms_auth
MYSQL_PASSWORD=change_this_db_password
MYSQL_ROOT_PASSWORD=change_this_root_password

APP_JWT_SECRET=change_this_to_a_long_random_secret
APP_JWT_EXPIRE_MINUTES=120

APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change_this_admin_password
APP_ALLOWED_ORIGINS=*
APP_ADMIN_PORT=1145

APP_REGISTER_ATTEMPT_LIMIT=10
APP_REGISTER_ATTEMPT_WINDOW_SECONDS=300
APP_REGISTER_PER_IP_LIMIT=1
APP_REGISTER_PER_IP_WINDOW_SECONDS=86400

# 浏览器端访问 auth_api 的对外 URL（注册页 JS 跨域调用）
# 部署时改为真实地址，例如 http://your-server-ip:17306 或 https://api.example.com
APP_REGISTER_PUBLIC_AUTH_URL=http://your-server-ip:17306
